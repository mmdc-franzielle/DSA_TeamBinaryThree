// =====================================================================
// CLASS DEFINITIONS
// =====================================================================
 
STRUCTURE Motorcycle:
    id       : INTEGER
    brand    : STRING
    model    : STRING
    quantity : INTEGER
    price    : FLOAT
 
    FUNCTION getId()       : RETURN id
    FUNCTION getBrand()    : RETURN brand
    FUNCTION getModel()    : RETURN model
    FUNCTION getQuantity() : RETURN quantity
    FUNCTION getPrice()    : RETURN price
    PROCEDURE setQuantity(quantity) : this.quantity = quantity
END STRUCTURE
 
STRUCTURE BrandNode:
    brand       : STRING
    motorcycles : LIST OF Motorcycle
    left        : POINTER TO BrandNode
    right       : POINTER TO BrandNode
 
    PROCEDURE addMotorcycle(m) : ADD m TO motorcycles
END STRUCTURE
 
STRUCTURE Transaction:
    id     : INTEGER
    change : INTEGER
END STRUCTURE
 
STRUCTURE UndoRecord:
    id         : INTEGER
    undoAmount : INTEGER
END STRUCTURE
 
// =====================================================================
// CLASS: Inventory
// Core system object — owns all data structures and methods
// =====================================================================
 
STRUCTURE Inventory:
    hashMap_inventory : HashMap       // Key: Motorcycle ID → O(1) lookup
    bst               : BrandBST      // Sorted by brand name
    bstRoot           : BrandNode     // BST root node
    mergeSort         : MergeSort     // For report generation
    transactionQueue  : Queue         // FIFO — stock in/out
    undoStack         : Stack         // LIFO — undo operations
    DEFAULT_QUANTITY  : INTEGER = 10
 
    // ── Constructor ──────────────────────────────────────
    PROCEDURE initialize():
        hashMap_inventory = new HashMap()
        bst               = new BrandBST()
        bstRoot           = NULL
        mergeSort         = new MergeSort()
        transactionQueue  = new Queue()
        undoStack         = new Stack()
    END PROCEDURE
 
    // ── Add motorcycle to HashMap and BST ────────────────
    PROCEDURE addMotorcycle(bike):
        hashMap_inventory.put(bike.getId(), bike)
        bstRoot = bst.insert(bstRoot, bike)
    END PROCEDURE
 
    // ── Load from CSV ─────────────────────────────────────
    FUNCTION loadFromCSV(filename):
        IF file NOT EXISTS THEN RETURN false
        OPEN file FOR READING
        SKIP header row
        WHILE NOT end of file DO
            READ line
            fields = parseCSVLine(line)
            id       = fields[0]
            fullName = fields[1]           // e.g. "Honda CBR500R"
            price    = fields[5]
            quantity = DEFAULT_QUANTITY
            brand    = first word of fullName
            model    = remaining words of fullName
            addMotorcycle(new Motorcycle(id, brand, model, quantity, price))
        END WHILE
        RETURN true
    END FUNCTION
 
    // ── Parse CSV line (handles quoted fields) ────────────
    FUNCTION parseCSVLine(line):
        FOR EACH character IN line:
            IF character = '"' THEN toggle inQuotes
            ELSE IF character = ',' AND NOT inQuotes THEN save field
            ELSE append character to current field
        END FOR
        RETURN fields
    END FUNCTION
 
    // ── Load fallback sample data ─────────────────────────
    PROCEDURE loadSampleData():
        CREATE 7 sample Motorcycle objects
        FOR EACH bike: addMotorcycle(bike)
    END PROCEDURE
 
    // ── Queue a transaction ───────────────────────────────
    PROCEDURE queueTransaction(id, change):
        transactionQueue.add(new Transaction(id, change))
    END PROCEDURE
 
    // ── Process all queued transactions (FIFO) ────────────
    PROCEDURE processTransactions():
        WHILE transactionQueue NOT EMPTY DO
            t = transactionQueue.poll()
            IF hashMap_inventory CONTAINS t.getId() THEN
                bike = hashMap_inventory.get(t.getId())
                IF t.getChange() < 0 AND bike.getQuantity() < ABS(t.getChange()) THEN
                    PRINT "Insufficient stock"
                    CONTINUE
                END IF
                bike.setQuantity(bike.getQuantity() + t.getChange())
                hashMap_inventory.put(bike.getId(), bike)
                undoStack.push(new UndoRecord(bike.getId(), -t.getChange()))
            ELSE
                PRINT "Motorcycle ID not found"
            END IF
        END WHILE
    END PROCEDURE
 
    // ── Search by ID — HashMap O(1) ───────────────────────
    PROCEDURE searchByID(id):
        IF hashMap_inventory CONTAINS id THEN
            m = hashMap_inventory.get(id)
            PRINT m.getId(), m.getBrand(), m.getModel(), m.getQuantity(), m.getPrice()
        ELSE
            PRINT "No motorcycle found with ID: " + id
        END IF
    END PROCEDURE
 
    // ── View all brands — BST in-order traversal ──────────
    PROCEDURE viewAllBrands():
        bst.inOrder(bstRoot)
    END PROCEDURE
 
    // ── Generate report — Merge Sort ──────────────────────
    PROCEDURE generateReport():
        flatList = []
        bst.flatten(bstRoot, flatList)       // Step 1: flatten BST
        sorted = mergeSort.sort(flatList)     // Step 2: sort by brand + model
        FOR EACH bike IN sorted:              // Step 3: print + accumulate totals
            PRINT bike details
            totalValue += bike.getQuantity() * bike.getPrice()
            totalUnits += bike.getQuantity()
        END FOR
        PRINT total items, units, value, unique brands
    END PROCEDURE
 
    // ── Undo last transaction — Stack LIFO ───────────────
    PROCEDURE undoLastTransaction():
        IF undoStack IS EMPTY THEN PRINT "Nothing to undo" · RETURN
        last = undoStack.pop()
        bike = hashMap_inventory.get(last.getId())
        bike.setQuantity(bike.getQuantity() + last.getUndoAmount())
        hashMap_inventory.put(bike.getId(), bike)
    END PROCEDURE
 
    // ── Rebuild BST from HashMap ──────────────────────────
    PROCEDURE rebuildBST():
        bstRoot = NULL
        FOR EACH bike IN hashMap_inventory.values():
            bstRoot = bst.insert(bstRoot, bike)
        END FOR
    END PROCEDURE
 
    // ── Save to CSV ───────────────────────────────────────
    PROCEDURE saveToCSV():
        OPEN "motorcycle_inventory.csv" FOR WRITING
        WRITE header: "ID,BRAND,MODEL,QUANTITY,PRICE"
        FOR EACH bike IN hashMap_inventory.values():
            WRITE bike.getId(), bike.getBrand(), bike.getModel(),
                  bike.getQuantity(), bike.getPrice()
        END FOR
        CLOSE file
    END PROCEDURE
 
END STRUCTURE
 
// =====================================================================
// BST INSERTION — Recursive
// =====================================================================
 
FUNCTION BrandBST.insert(root, bike):
    IF root = NULL THEN
        CREATE new BrandNode(bike.getBrand())
        node.addMotorcycle(bike)
        RETURN node
    END IF
    cmp = bike.getBrand().compareToIgnoreCase(root.getBrand())
    IF cmp < 0 THEN root.left  = insert(root.left, bike)
    ELSE IF cmp > 0 THEN root.right = insert(root.right, bike)
    ELSE root.addMotorcycle(bike)       // Same brand — group in node
    RETURN root
END FUNCTION
 
// =====================================================================
// BST IN-ORDER TRAVERSAL — Recursive
// =====================================================================
 
PROCEDURE BrandBST.inOrder(node):
    IF node = NULL THEN RETURN
    inOrder(node.left)
    PRINT node.getBrand()
    FOR EACH bike IN node.getMotorcycles(): PRINT bike details
    inOrder(node.right)
END PROCEDURE
 
// =====================================================================
// BST FLATTEN — Recursive (bridge to Merge Sort)
// =====================================================================
 
PROCEDURE BrandBST.flatten(node, list):
    IF node = NULL THEN RETURN
    flatten(node.left, list)
    list.addAll(node.getMotorcycles())
    flatten(node.right, list)
END PROCEDURE
 
// =====================================================================
// MERGE SORT — Recursive, O(n log n)
// Sorts by brand, then model if same brand
// =====================================================================
 
FUNCTION MergeSort.sort(list):
    IF LENGTH(list) <= 1 THEN RETURN list
    mid   = LENGTH(list) / 2
    left  = sort(list[0..mid])
    right = sort(list[mid..end])
    RETURN merge(left, right)
END FUNCTION
 
FUNCTION MergeSort.merge(left, right):
    result = []
    WHILE left AND right NOT EMPTY DO
        brandCmp = left[0].getBrand().compareToIgnoreCase(right[0].getBrand())
        IF brandCmp < 0  THEN APPEND left[0]  to result
        ELSE IF brandCmp > 0  THEN APPEND right[0] to result
        ELSE
            modelCmp = left[0].getModel().compareToIgnoreCase(right[0].getModel())
            IF modelCmp <= 0 THEN APPEND left[0]  to result
            ELSE                  APPEND right[0] to result
        END IF
    END WHILE
    APPEND remaining items from left and right
    RETURN result
END FUNCTION
 
// =====================================================================
// MAIN PROGRAM — DSA_MotorPHInventorySystem
// =====================================================================
 
BEGIN
 
    inventory = new Inventory()
    inventory.initialize()
 
    // Step 1: Load from CSV
    loaded = inventory.loadFromCSV("MotorPH_Products_List_2025.csv")
 
    // Step 2: Fall back to sample data if CSV not found
    IF NOT loaded OR inventory.size() = 0 THEN
        inventory.loadSampleData()
    END IF
 
    // Step 3: Queue sample transactions
    ids = inventory.getSortedIDs()
    inventory.queueTransaction(ids[0], -2)
    inventory.queueTransaction(ids[1], -1)
    inventory.queueTransaction(ids[2], +5)
    inventory.queueTransaction(ids[3], -1)
 
    // Step 4: Process transactions
    inventory.processTransactions()
 
    // Step 5: Launch menu
    LOOP until choice = 7:
        DISPLAY menu options 1–7
        GET choice
        SWITCH choice:
            CASE 1 → inventory.searchByID(id)
            CASE 2 → inventory.viewAllBrands()
            CASE 3 → inventory.generateReport()
            CASE 4 → inventory.undoLastTransaction()
            CASE 5 → inventory.rebuildBST()
            CASE 6 → inventory.saveToCSV()
            CASE 7 → inventory.saveToCSV() · EXIT
        END SWITCH
    END LOOP
 
END
